{
  "version": "v2_initial",
  "description": "Experimental V2 shadow scorer — provisional anchors derived from V1 thresholds and trial data.",
  "category_weights": {
    "control": 0.4,
    "efficiency": 0.3,
    "target_stability": 0.3
  },
