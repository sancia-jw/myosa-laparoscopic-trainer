      "name": "course_smoothness_gyro_rms",
      "category": "control",
      "direction": "lower_is_better",
      "good": 130.0,
      "okay": 195.0,
      "bad": 260.0,
      "weight": 0.55,
      "enabled": true,
      "confidence": "high",
      "source": "derived_from_v1_threshold",
      "derivation_note": "V1 course gyro RMS good/bad 130/260; okay at midpoint.",
      "units": "deg/s",
      "valid_min": 0.0,
      "valid_max": 800.0,
      "final_score_field": "course_gyro_rms"
    },
    {
      "name": "correction_spike_rate",
      "category": "control",
      "direction": "lower_is_better",
      "good": 5.5,
      "okay": 8.25,
      "bad": 11.0,
      "weight": 0.45,
      "enabled": true,
      "confidence": "high",
      "source": "derived_from_v1_threshold",
      "derivation_note": "V1 course spike rate good/bad 5.5/11.0 spikes per second.",
